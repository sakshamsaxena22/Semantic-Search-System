# Environment files — never commit secrets
.env
**/.env
*.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
.venv/
env/

# VS Code
.vscode/

# Uploaded documents + ChromaDB persist dir (runtime data, not source)
backend/data/*
!backend/data/.gitkeep
# ChromaDB on-disk store
backend/data/chroma_db/

# Docker
*.dockerignore

# Local secrets / notes with credentials (e.g. *.txt files with keys)
*.secret.txt
